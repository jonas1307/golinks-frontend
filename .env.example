AUTH0_DOMAIN = "Your Auth0 tenant domain (e.g., your-tenant.us.auth0.com)."
AUTH0_CLIENT_ID = "The unique identifier for your specific application."
AUTH0_CLIENT_SECRET = "The secret key used to encrypt the connection. Never expose this to the frontend."
AUTH0_SECRET = "A long, random 32-byte string used to encrypt session cookies."
APP_BASE_URL = "The root URL of your own application (e.g., http://localhost:3000)."
AUTH0_AUDIENCE='The unique identifier for your API (e.g., https://your-tenant/api).'
AUTH0_SCOPE='The permissions your application is requesting from the user (e.g., openid profile email).'
NEXT_PUBLIC_API_BASE_URL='The base URL for your API endpoints (e.g., http://localhost:8081).'
